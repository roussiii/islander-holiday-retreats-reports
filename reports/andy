<script>
// Set date
document.getElementById('lastUpdated').textContent = new Date().toLocaleDateString('en-GB',{day:'numeric',month:'long',year:'numeric'});

// Tab switching
function showPanel(id){
  document.querySelectorAll('.panel').forEach(p=>p.classList.remove('active'));
  document.querySelectorAll('.tab').forEach(t=>t.classList.remove('active'));
  document.getElementById('panel-'+id).classList.add('active');
  event.target.classList.add('active');
}

// Checklist toggle
function toggleCheck(row){
  const box = row.querySelector('.check-box');
  const isDone = box.classList.toggle('done');
  row.classList.toggle('done-row', isDone);
  updateChecklistBadge();
  updateStats();
}

function updateChecklistBadge(){
  const total = document.querySelectorAll('.check-row').length;
  const done = document.querySelectorAll('.check-box.done').length;
  const badge = document.querySelector('#panel-checklist .badge');
  if(badge) badge.textContent = done+' / '+total+' done';
}

// Stats counters — update as items are filled in
function updateStats(){
  const done = document.querySelectorAll('.check-box.done').length;
  document.getElementById('cnt-done').textContent = done;
  // Critical = dot-bad count
  document.getElementById('cnt-critical').textContent = document.querySelectorAll('.dot-bad').length;
  // Works = dot-warn count
  document.getElementById('cnt-works').textContent = document.querySelectorAll('.dot-warn').length;
  // Checklist total minus done
  const total = document.querySelectorAll('.check-row').length;
  document.getElementById('cnt-checklist').textContent = total - done;
}

updateStats();
</script>
